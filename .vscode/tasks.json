{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build SDL2 project",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-g",
                "-o",
                "engine.exe",
                "src/*.cpp",
                "src/**/*.cpp",
                "-IC:/msys64/mingw64/include/SDL2",
                "-Dmain=SDL_main",
                "-LC:/msys64/mingw64/lib",
                "-lSDL2"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        }
    ]
}